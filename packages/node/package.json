{
  "name": "@forvais/eslint-config-node",
  "description": "Node ESLint config",
  "version": "4.1.0",
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "license": "MIT",
  "author": "Ben Chiang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forvais/eslint-config-mono.git"
  },
  "main": "./dist/index.cjs",
  "scripts": {
    "build": "tsdown",
    "lint": "npm-run-all lint:*",
    "lint:eslint": "eslint index.mjs --no-error-on-unmatched-pattern"
  },
  "peerDependencies": {
    "eslint": "^10.4.0",
    "eslint-plugin-n": "^18.0.1",
    "globals": "^17.6.0"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "eslint-plugin-n": "^18.0.1",
    "globals": "^17.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.4.0"
}
